# Refuge House Compliance API - Environment Variables
# Copy this to .env and fill in your values.

# ── Server ──────────────────────────────────────────
PORT=3100
NODE_ENV=development

# ── Authentication ──────────────────────────────────
# API key that Pulse (and other apps) must send in the x-api-key header.
# Generate a random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Leave blank in development to disable auth.
COMPLIANCE_API_KEY=

# ── Anthropic (Claude) ──────────────────────────────
# Separate key from Pulse so usage is tracked independently.
# You can use the same key if you prefer — just copy ANTHROPIC_PULSE_KEY here.
ANTHROPIC_COMPLIANCE_KEY=
ANTHROPIC_COMPLIANCE_MODEL=claude-sonnet-4-5
# Fast model used for document selection (Pass 1 of two-pass retrieval).
# Haiku is much faster and cheaper for this simple retrieval task.
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001

# ── RadiusCompliance Database ─────────────────────────
# Same Azure SQL server as RadiusBifrost, separate database.
# In Azure App Settings, use KeyVault references for DB_PASSWORD.
COMPLIANCE_DB_USER=bifrostadmin
COMPLIANCE_DB_PASSWORD=
COMPLIANCE_DB_SERVER=refugehouse-bifrost-server.database.windows.net
COMPLIANCE_DB_NAME=RadiusCompliance

# ── Knowbase Repository ─────────────────────────────
# URL of the policy documents repository.
KNOWBASE_REPO_URL=https://github.com/jduarte-refugehouse/refuge-house-knowbase.git

# How often (in minutes) to pull the latest knowbase changes. Default: 30
KNOWBASE_REFRESH_MINUTES=30

# ── Public Console Abuse Controls (no impact on /api/*) ─────────────
# Rate-limit window for /console/chat requests in milliseconds.
PUBLIC_CONSOLE_RATE_LIMIT_WINDOW_MS=60000
# Max requests per IP inside the window.
PUBLIC_CONSOLE_RATE_LIMIT_MAX_REQUESTS=25
# Max characters accepted for a single public console message.
PUBLIC_CONSOLE_MAX_MESSAGE_CHARS=4000

# ── Pulse Integration (Webhooks) ─────────────────────
# URL that this API POSTs compliance events to (reminders, regulatory changes, sync results).
# Pulse receives these and sends emails / shows UI alerts.
# Leave blank in development — events will be logged but not sent.
PULSE_WEBHOOK_URL=
# Shared secret sent in X-Webhook-Secret header for webhook authentication.
PULSE_WEBHOOK_SECRET=
